{
  "name": "boolepad",
  "publisher": "madebymaxi",
  "icon": "resources/icon.png",
  "displayName": "boolepad",
  "description": "Extensión de sintaxis recomendada por la cátedra de la FACET (UNT) para pseudocódigo",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "scripts": {
    "package": "vsce package",
    "vscode:prepublish": "echo 'Listo para empaquetar'"
  },
  "devDependencies": {
    "vsce": "^2.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devnotmax/boolepad.git"
  },
  "bugs": {
    "url": "https://github.com/devnotmax/boolepad/issues"
  },
  "homepage": "https://github.com/devnotmax/boolepad#readme",
  "keywords": [
    "pseudocode",
    "pseudocodigo",
    "syntax",
    "boolepad"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "boolepad",
        "aliases": [
          "Boolepad Pseudocódigo",
          "boolepad"
        ],
        "extensions": [
          ".pseudo",
          ".txt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "boolepad",
        "scopeName": "source.boolepad",
        "path": "./syntaxes/pseudocodigo.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "boolepad",
        "path": "./snippets/snippets.json"
      }
    ]
  }
}
